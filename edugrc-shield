<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduGRC-Shield | Interactive Compliance Simulation Lab</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #0f172a; color: #f8fafc; margin: 0; padding: 20px; }
        .container { max-width: 900px; margin: 0 auto; background: #1e293b; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.3); }
        h1 { color: #38bdf8; border-bottom: 2px solid #334155; padding-bottom: 10px; }
        .panel { display: flex; gap: 20px; margin-top: 20px; }
        .controls { flex: 1; background: #0f172a; padding: 20px; border-radius: 8px; }
        .output { flex: 1; background: #020617; padding: 20px; border-radius: 8px; font-family: 'Courier New', Courier, monospace; color: #4ade80; white-space: pre-wrap; font-size: 13px; border: 1px solid #1e293b; }
        .toggle-btn { display: block; width: 100%; padding: 12px; margin: 10px 0; background: #334155; color: white; border: none; border-radius: 6px; cursor: pointer; text-align: left; font-weight: bold; }
        .toggle-btn.active { background: #0284c7; border-left: 5px solid #38bdf8; }
        .status-bar { background: #334155; padding: 10px; border-radius: 6px; font-weight: bold; margin-bottom: 20px; text-align: center; }
        .status-bar.compliant { background: #16a34a; }
    </style>
</head>
<body>

<div class="container">
    <h1>🔬 EduGRC-Shield: AI Safety Lab</h1>
    <p><strong>Scenario:</strong> You are auditing a High-Risk STEM AI Healthcare Model. Implement the correct technical controls to satisfy <strong>EU AI Act Article 10 & 13</strong> mandates.</p>
    
    <div id="statusBar" class="status-bar" style="background-color: #dc2626;">SYSTEM STATUS: NON-COMPLIANT (CRITICAL VULNERABILITIES)</div>

    <div class="panel">
        <div class="controls">
            <h3>Deploy Governance Controls:</h3>
            <button id="btn1" class="toggle-btn" onclick="toggleControl(1)">[ ] Enable Data Provenance Logging (Art. 10)</button>
            <button id="btn2" class="toggle-btn" onclick="toggleControl(2)">[ ] Inject SHAP Explainability Matrix (Art. 13)</button>
            <button id="btn3" class="toggle-btn" onclick="toggleControl(3)">[ ] Enforce Immutable WORM Audit Trails</button>
        </div>
        
        <div class="output" id="codeOutput">// Real-time Infrastructure-as-Code Configuration Log will appear here...</div>
    </div>
</div>

<script>
    let states = { 1: false, 2: false, 3: false };

    function toggleControl(id) {
        states[id] = !states[id];
        document.getElementById('btn' + id).classList.toggle('active');
        
        let btn = document.getElementById('btn' + id);
        if(id === 1) btn.innerText = states[1] ? "[✓] Data Provenance Logging Active" : "[ ] Enable Data Provenance Logging (Art. 10)";
        if(id === 2) btn.innerText = states[2] ? "[✓] SHAP Explainability Matrix Injected" : "[ ] Inject SHAP Explainability Matrix (Art. 13)";
        if(id === 3) btn.innerText = states[3] ? "[✓] Immutable Audit Trail Enforced" : "[ ] Enforce Immutable WORM Audit Trails";

        updateSimulation();
    }

    function updateSimulation() {
        let output = "";
        if(states[1]) output += "// Data Provenance Active\nInbound_S3_Bucket.enforce_metadata_tagging('data_provenance_manifest.json');\n\n";
        if(states[2]) output += "// Explainability Pipeline Active\nDeploy_Model_API.integrate_layer('SHAP_Explainability_Log.db');\n\n";
        if(states[3]) output += "// Security Lock Policy Active\nS3_Bucket.apply_policy('EnforceImmutableComplianceLogging');\n";
        
        if(!states[1] && !states[2] && !states[3]) output = "// Real-time Infrastructure-as-Code Configuration Log will appear here...";
        
        document.getElementById('codeOutput').innerText = output;

        let statusBar = document.getElementById('statusBar');
        if(states[1] && states[2] && states[3]) {
            statusBar.innerText = "SYSTEM STATUS: 100% COMPLIANT SECURE OUTCOME REACHED";
            statusBar.style.backgroundColor = "#16a34a";
        } else {
            statusBar.innerText = "SYSTEM STATUS: NON-COMPLIANT (PENDING CONTROLS)";
            statusBar.style.backgroundColor = "#dc2626";
        }
    }
</script>
</body>
</html>
